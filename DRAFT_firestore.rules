rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users can't list other users
      
      function isValidUser(data) {
        return data.get('uid', '') == request.auth.uid &&
               data.email is string && data.email.size() <= 256;
      }

      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                       incoming().keys().hasAll(['uid', 'email']) && incoming().keys().size() >= 2;
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    // --- Courses Collection ---
    match /courses/{courseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      function isValidCourse(data) {
         return data.title is string && data.title.size() <= 200 &&
                data.description is string && data.description.size() <= 5000;
      }

      allow create: if false; // Only admins via console for now
      allow update: if false; 
      allow delete: if false;
    }

    // --- Enrollments Collection ---
    match /enrollments/{enrollmentId} {
      allow get: if isSignedIn() && (isOwner(existing().userId));
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidEnrollment(data) {
        return data.userId == request.auth.uid &&
               data.courseId is string &&
               data.enrolledAt == request.time;
      }

      allow create: if isSignedIn() && isValidEnrollment(incoming()) &&
                       incoming().keys().hasAll(['userId', 'courseId', 'enrolledAt', 'status']) &&
                       get(/databases/$(database)/documents/courses/$(incoming().courseId)) != null;
      allow update: if isOwner(existing().userId) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'progress', 'updatedAt']);
      allow delete: if false;
    }
  }
}
